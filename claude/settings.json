{
	"statusLine": {
		"type": "command",
		"command": "assist status-line"
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [{ "type": "command", "command": "assist cli-hook" }]
			},
			{
				"matcher": "PowerShell",
				"hooks": [{ "type": "command", "command": "assist cli-hook" }]
			},
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [{ "type": "command", "command": "assist edit-hook" }]
			}
		],
		"Notification": [
			{
				"matcher": "",
				"hooks": [{ "type": "command", "command": "assist notify" }]
			}
		],
		"SessionStart": [
			{
				"matcher": "",
				"hooks": [{ "type": "command", "command": "assist handover load" }]
			}
		]
	},
	"permissions": {
		"allow": [
			"SlashCommand(/verify)",
			"SlashCommand(/commit)",
			"SlashCommand(/devlog)",
			"SlashCommand(/refactor)",
			"SlashCommand(/review-comments)",
			"SlashCommand(/transcript-format)",
			"SlashCommand(/transcript-summarise)",
			"SlashCommand(/voice-setup)",
			"SlashCommand(/voice-start)",
			"SlashCommand(/voice-stop)",
			"SlashCommand(/voice-status)",
			"SlashCommand(/voice-logs)",
			"SlashCommand(/journal)",
			"SlashCommand(/standup)",
			"Skill(verify)",
			"Skill(commit)",
			"Skill(devlog)",
			"Skill(refactor)",
			"Skill(review-comments)",
			"Skill(transcript-format)",
			"Skill(transcript-summarise)",
			"Skill(journal)",
			"Skill(standup)",
			"Skill(voice-setup)",
			"Skill(voice-start)",
			"Skill(voice-stop)",
			"Skill(voice-status)",
			"Skill(voice-logs)",
			"Skill(jira)",
			"SlashCommand(/jira)",
			"Skill(seq)",
			"SlashCommand(/seq)",
			"SlashCommand(/sql)",
			"Skill(inspect)",
			"SlashCommand(/inspect)",
			"Skill(prompts)",
			"SlashCommand(/prompts)",
			"Skill(screenshot)",
			"SlashCommand(/screenshot)",
			"Skill(draft)",
			"SlashCommand(/draft)",
			"Skill(next-backlog-item)",
			"SlashCommand(/next)",
			"Skill(test-cover)",
			"SlashCommand(/test-cover)",
			"Skill(test-review)",
			"SlashCommand(/test-review)",
			"Skill(handover)",
			"SlashCommand(/handover)",
			"Skill(recall)",
			"SlashCommand(/recall)",
			"Skill(strip-comments)",
			"SlashCommand(/strip-comments)",
			"Bash(git ls-files:*)",
			"WebFetch(domain:staffordwilliams.com)"
		],
		"deny": ["Bash(npm run:*)", "Read(~/.assist/restricted/**)"]
	}
}
